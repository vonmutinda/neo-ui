# neo-ui — copy to .env.local and fill for local dev.
# On Railway, set these in the neo-ui service variables to connect to neo-api.

# API base URL (used for fetch in browser and server).
# Local: http://localhost:8080
# Production: set to your neo-api public URL (e.g. https://neo-api-production-xxxx.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8080
