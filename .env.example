# enviar-ui — copy to .env.local and fill for local dev.
# On Railway, set these in the enviar-ui service variables to connect to enviar-api.

# API base URL (used for fetch in browser and server).
# Local: http://localhost:8080
# Production: set to your enviar-api public URL (e.g. https://enviar-api-production-xxxx.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8080
