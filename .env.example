# neo-ui — copy to .env.local and fill for local dev.
# On Railway, set these in the service variables.

# API base URL (used for fetch in browser and server)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: override for production (e.g. https://api.neo.et)
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
